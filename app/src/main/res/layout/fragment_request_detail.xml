<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/bus_screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/detailRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LH → City Center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/bus_on_surface" />

        <TextView
            android:id="@+id/detailDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2026-05-01 • 09:00"
            android:textColor="@color/bus_on_surface_variant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Status Timeline"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/bus_on_surface" />

        <LinearLayout
            android:id="@+id/timelineContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/detailPurpose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Purpose: Medical appointment"
            android:textColor="@color/bus_on_surface_variant" />

    </LinearLayout>
</ScrollView>
